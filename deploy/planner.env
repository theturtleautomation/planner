# ║                                                                            ║
# ║   Environment Configuration                                                ║
# ║   Installed to: /etc/planner/planner.env                                   ║
# ║   Loaded by: systemd EnvironmentFile directive                             ║
# ║                                                                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# This file configures the Planner server runtime. It is read by systemd when
# the planner.service starts. The install script will NOT overwrite this file
# once it exists — your local edits are safe across upgrades.
#
# SYNTAX: KEY=value (no spaces around '=', no 'export', no quotes needed
# unless value contains spaces). Lines starting with '#' are comments.
# Blank lines are ignored. This is a systemd EnvironmentFile, not a shell script.


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: SERVER
# ═══════════════════════════════════════════════════════════════════════════════
#
# Core server settings. The port is also specified in the systemd unit's
# ExecStart — if you change it here, update planner.service to match.

# HTTP port the Axum server binds to. Default: 3100
# PLANNER_PORT=3100

# Bind address. Default: 0.0.0.0 (all interfaces).
# To restrict to localhost only: PLANNER_BIND=127.0.0.1
# PLANNER_BIND=0.0.0.0


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: LOGGING
# ═══════════════════════════════════════════════════════════════════════════════
#
# Planner uses the tracing crate with env_filter. The RUST_LOG variable
# controls what gets logged. Logs go to journald via systemd.
#
# View logs:    journalctl -u planner -f
# Full debug:   RUST_LOG=debug
# Server only:  RUST_LOG=planner_server=debug
# Quiet:        RUST_LOG=warn
#
# Syntax supports per-crate granularity:
#   RUST_LOG=planner_server=info,planner_core=debug,tower_http=warn

RUST_LOG=planner_server=info,planner_core=info


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: AUTHENTICATION (Auth0)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Planner supports Auth0 JWT validation for production deployments.
# When these are unset, the server runs in DEV MODE — no authentication,
# all endpoints are open. This is fine for local/trusted networks.
#
# To enable Auth0:
#   1. Create an Auth0 API application
#   2. Set the three variables below
#   3. Restart: sudo systemctl restart planner
#
# The server validates JWTs on every protected endpoint. Tokens are
# verified against Auth0's JWKS endpoint (RS256) or a shared secret (HS256).

# Your Auth0 tenant domain (without https://)
# AUTH0_DOMAIN=your-tenant.us.auth0.com

# The API audience identifier you registered in Auth0
# AUTH0_AUDIENCE=https://api.planner.example.com

# (Optional) Shared secret for HS256 token validation.
# Most setups use RS256 with JWKS auto-discovery and don't need this.
# Only set if your Auth0 app uses HS256 signing.
# AUTH0_SECRET=your-256-bit-secret


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4: WEB FRONTEND (Vite build-time)
# ═══════════════════════════════════════════════════════════════════════════════
#
# ⚠️  These are NOT read at server runtime. They are baked into the JS bundle
# at build time by Vite. Set them BEFORE running `make web-build` or the
# install script. They are documented here for completeness.
#
# If you change these, you must rebuild the frontend:
#   cd planner-web && npm run build
#   — or —
#   sudo ./deploy/install.sh --update
#
# Create a .env file in planner-web/ for local dev, or export before building.

# Auth0 domain for the SPA (same as AUTH0_DOMAIN above)
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 SPA Client ID (from your Auth0 Application settings)
# VITE_AUTH0_CLIENT_ID=abc123def456

# Auth0 API audience (same as AUTH0_AUDIENCE above)
# VITE_AUTH0_AUDIENCE=https://api.planner.example.com

# API base URL. Default: /api (same-origin, proxied by the Rust server).
# Only change if you're running the frontend separately from the API.
# VITE_API_BASE=/api


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5: LLM PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════════
#
# Planner uses native CLI tools for LLM access. Each provider can
# authenticate via interactive subscription login only.
#
#   ┌─────────────┬────────────┬──────────────────────────────────────────────┐
#   │ Provider    │ CLI Binary │ Auth Methods                                 │
#   ├─────────────┼────────────┼──────────────────────────────────────────────┤
#   │ Anthropic   │ claude     │ claude login                                 │
#   │ Google      │ gemini     │ gemini auth login                            │
#   │ OpenAI      │ codex      │ codex login                                  │
#   └─────────────┴────────────┴──────────────────────────────────────────────┘
#
# The server checks PATH for each CLI at startup and logs which are
# available. At minimum ONE provider must be installed. For the full
# pipeline (Socratic intake + factory worker), you need:
#
#   - claude OR gemini   → Socratic dialogue, planning, verification
#   - codex              → Factory worker code generation (gpt-5.3-codex)
#
# ── Interactive Login (runs as the planner service user) ─────────────────
#
# Each CLI stores credentials in its isolated home under /opt/planner/cli-home/:
#
#   sudo -u planner HOME=/opt/planner/cli-home/claude /opt/planner/bin/claude login
#   sudo -u planner HOME=/opt/planner/cli-home/gemini /opt/planner/bin/gemini auth login
#   sudo -u planner HOME=/opt/planner/cli-home/codex  CODEX_HOME=/opt/planner/cli-home/codex/.codex /opt/planner/bin/codex login
#
# Planner intentionally does not forward API keys to provider CLIs.
# Authenticate the installed CLIs in their isolated homes instead.


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 6: FACTORY WORKER (Code Generation)
# ═══════════════════════════════════════════════════════════════════════════════
#
# The factory worker uses `codex exec` to generate code in isolated
# worktrees. These settings control its sandbox and filesystem behavior.

# Root directory for temporary worktrees. Each factory run creates a
# subdirectory here, populates it with project context, hands it to
# codex, and collects the output. Cleaned up after each run.
# Default: /tmp/planner-worktrees
# PLANNER_WORKTREE_ROOT=/tmp/planner-worktrees

# Codex sandbox mode. Controls how codex exec is sandboxed.
# The server auto-detects the best available mode at runtime:
#
#   full-auto        → Landlock + seccomp (preferred, requires kernel ≥6.x)
#   workspace-write  → Write access scoped to the worktree directory
#
# Only set this to override auto-detection. You almost never need to.
# PLANNER_CODEX_SANDBOX=full-auto


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: VAULT INTEGRATION (Future)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Planner is designed to avoid secrets in flat files. The LLM CLIs handle
# their own credential storage, and Auth0 uses JWKS (no secret needed
# for RS256). However, if your deployment requires centralized secret
# management, here's how to integrate:
#
# ── HashiCorp Vault ──────────────────────────────────────────────────────
#
# Option A: Use vault agent to template this env file automatically.
# Vault Agent can watch secrets and rewrite /etc/planner/planner.env
# whenever they rotate, then HUP the service:
#
#   # /etc/vault-agent.d/planner.hcl
#   template {
#     source      = "/etc/vault-agent.d/planner.env.ctmpl"
#     destination = "/etc/planner/planner.env"
#     command     = "systemctl restart planner"
#   }
#
# Option B: Use systemd's LoadCredential directive (systemd ≥250).
# Secrets are passed as files in /run/credentials/planner.service/
# and never touch disk in plaintext:
#
#   # In planner.service [Service] section:
#   LoadCredential=auth0-secret:/etc/credstore/auth0-secret
#
# Then read at runtime via:
#   /run/credentials/planner.service/auth0-secret
#
# Option C: ExecStartPre with vault CLI to inject into environment:
#
#   # In planner.service [Service] section:
#   ExecStartPre=/usr/bin/vault kv get -field=auth0_secret secret/planner > /run/planner/auth0.env
#   EnvironmentFile=/run/planner/auth0.env
#
# ── SOPS ─────────────────────────────────────────────────────────────────
#
# For encrypted-at-rest config committed to git:
#
#   sops -e deploy/planner.env > deploy/planner.env.enc
#   sops -d deploy/planner.env.enc > /etc/planner/planner.env
#
# Add to install.sh or a CI/CD pipeline as needed.
#
# ── systemd-creds (systemd ≥250) ─────────────────────────────────────────
#
# Native systemd encryption tied to the machine's TPM or /var/lib/systemd:
#
#   systemd-creds encrypt --name=auth0-secret - /etc/credstore.encrypted/auth0-secret
#   # Then in planner.service:
#   LoadCredentialEncrypted=auth0-secret:/etc/credstore.encrypted/auth0-secret


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 8: DATA STORAGE
# ═══════════════════════════════════════════════════════════════════════════════
#
# CXDB (the belief state store) uses MessagePack files on the local
# filesystem. The data directory is owned by the planner service user.

# Base directory for CXDB data. Default: /opt/planner/data
# PLANNER_DATA_DIR=/opt/planner/data

# Session expiry in seconds. Inactive sessions are cleaned up by
# a background task. Default: 3600 (1 hour)
# PLANNER_SESSION_TTL=3600


# ═══════════════════════════════════════════════════════════════════════════════
# That's everything. Start the service:
#
#   sudo systemctl start planner
#   sudo systemctl status planner
#   journalctl -u planner -f
#
# If something breaks, the server logs exactly what's missing.
# No env var is required for a dev-mode startup — just run it.
# ═══════════════════════════════════════════════════════════════════════════════
