# /etc/planner/planner.env
# Planner server environment configuration
#
# Auth0 (optional — omit for dev mode)
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://api.planner.local

# Rust log level
RUST_LOG=planner_server=info

# Server port (also set in systemd ExecStart, keep in sync)
# PLANNER_PORT=3100
