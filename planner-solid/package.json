{
  "name": "planner-solid",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/export-static.mjs",
    "start": "vite start",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit --skipLibCheck",
    "test:e2e": "playwright test",
    "test:e2e:canonical-static": "playwright test --config playwright.canonical-static.config.ts e2e/phase-37-canonical-static-runtime.spec.ts",
    "test:e2e:frontend-mock": "VITE_PLANNER_FRONTEND_MOCK=1 playwright test --config playwright.frontend-mock.config.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "solid-js": "^1.9.5",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^27.0.1",
    "vitest": "^4.1.1"
  }
}
